<script>
	(() => {
		const fields = ['DNI', 'Name', 'Phone', 'Email'];

		document.querySelectorAll('[data-required-message], [data-invalid-message]').forEach((input) => {
			input.addEventListener('invalid', () => {
				input.setCustomValidity('');

				if (input.validity.valueMissing) {
					input.setCustomValidity(input.dataset.requiredMessage ?? 'This field is required.');
				} else if (input.validity.patternMismatch || input.validity.tooShort || input.validity.typeMismatch) {
					input.setCustomValidity(input.dataset.invalidMessage ?? 'The entered value is invalid.');
				}
			});

			input.addEventListener('input', () => {
				input.setCustomValidity('');
			});
		});

		document.querySelectorAll('[data-person-form="true"]').forEach((form) => {
			const shouldDetectChanges = form.dataset.detectPersonChanges === 'true';
			const noChangesMessageSelector = form.dataset.noChangesMessage;
			const noChangesMessage = noChangesMessageSelector
				? document.querySelector(noChangesMessageSelector)
				: null;

			const hideMessages = () => {
				document.querySelectorAll('.person-message').forEach((message) => {
					message.classList.add('d-none');
				});
			};

			if (!shouldDetectChanges) {
				return;
			}

			const initialValues = Object.fromEntries(
				fields.map((field) => {
					const input = form.querySelector(`[name="${field}"]`);
					return [field, input?.value ?? ''];
				})
			);

			form.addEventListener('submit', (event) => {
				const hasChanges = fields.some((field) => {
					const input = form.querySelector(`[name="${field}"]`);
					return (input?.value ?? '') !== initialValues[field];
				});

				if (!hasChanges) {
					event.preventDefault();
					hideMessages();
					noChangesMessage?.classList.remove('d-none');
				}
			});

			fields.forEach((field) => {
				const input = form.querySelector(`[name="${field}"]`);
				input?.addEventListener('input', hideMessages);
			});
		});

		document.querySelectorAll('[data-digits-only="true"]').forEach((input) => {
			input.addEventListener('beforeinput', (event) => {
				if (event.data && /\D/.test(event.data)) {
					event.preventDefault();
				}
			});

			input.addEventListener('input', () => {
				input.value = input.value.replace(/\D/g, '').slice(0, input.maxLength);
			});
		});
	})();
</script>
