@model PersonViewModel

@{
	ViewData["Title"] = "Create Person";
}

<section class="page-header">
	<div>
		<p class="page-kicker">Persons</p>
		<h1>Create person</h1>
	</div>
</section>

@if (!string.IsNullOrWhiteSpace(@Model.ErrorMessage))
{
	<div class="alert alert-danger" role="alert">
		@Model.ErrorMessage
	</div>
}

<section class="surface form-surface">
	<form asp-action="create" asp-controller="CreatePerson" data-person-form="true" method="post" class="person-form">
		<div class="person-form-grid">
			<partial name="Persons/PersonFormFields" model="Model" />
		</div>

		<div class="form-actions">
			<a asp-action="Index" asp-controller="GetPersons" class="btn btn-outline-secondary">Cancel</a>
			<button type="submit" class="btn btn-primary">Create Person</button>
		</div>
	</form>
</section>

@section Scripts {
	<partial name="Persons/PersonFormScripts" />
}
