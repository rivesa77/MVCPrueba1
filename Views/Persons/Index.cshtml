@model PersonSearchViewModel

@{
	ViewData["Title"] = "Persons";
	int visiblePagesAroundCurrent = 2;
	int firstVisiblePage = Math.Max(2, Model.PageNumber - visiblePagesAroundCurrent);
	int lastVisiblePage = Math.Min(Model.TotalPages - 1, Model.PageNumber + visiblePagesAroundCurrent);
	bool showFirstPageGap = firstVisiblePage > 2;
	bool showLastPageGap = lastVisiblePage < Model.TotalPages - 1;
}

<section class="page-header">
	<div>
		<p class="page-kicker">Directory</p>
		<h1>Persons</h1>
	</div>
	<a asp-action="Create" asp-controller="CreatePerson" class="btn btn-primary">Create Person</a>
</section>

<section class="surface person-search-surface">
	<form asp-action="Index" asp-controller="GetPersons" method="get" class="person-search-form">
		<div class="form-field">
			<label for="searchField" class="form-label">Search by</label>
			<select id="searchField" name="searchField" class="form-select">
				<option value="@PersonSearchField.All" selected="@(Model.SearchField == PersonSearchField.All)">All fields</option>
				<option value="@PersonSearchField.Dni" selected="@(Model.SearchField == PersonSearchField.Dni)">DNI</option>
				<option value="@PersonSearchField.Name" selected="@(Model.SearchField == PersonSearchField.Name)">Name</option>
				<option value="@PersonSearchField.Email" selected="@(Model.SearchField == PersonSearchField.Email)">Email</option>
				<option value="@PersonSearchField.Phone" selected="@(Model.SearchField == PersonSearchField.Phone)">Phone</option>
			</select>
		</div>
		<div class="form-field person-search-text">
			<label for="searchTerm" class="form-label">Search</label>
			<input id="searchTerm" name="searchTerm" type="search" class="form-control" value="@Model.SearchTerm" maxlength="75">
		</div>
		<div class="form-field">
			<label for="pageSize" class="form-label">Page size</label>
			<select id="pageSize" name="pageSize" class="form-select">
				<option value="5" selected="@(Model.PageSize == 5)">5</option>
				<option value="10" selected="@(Model.PageSize == 10)">10</option>
				<option value="15" selected="@(Model.PageSize == 15)">15</option>
			</select>
		</div>
		<input type="hidden" name="pageNumber" value="1">
		<div class="person-search-actions">
			<a asp-action="Index" asp-controller="GetPersons" class="btn btn-outline-secondary">Clear</a>
			<button type="submit" class="btn btn-primary">Search</button>
		</div>
	</form>
</section>

<section class="surface">
	<div class="table-responsive">
		<table class="table align-middle person-table">
			<thead>
				<tr>
					<th scope="col">DNI</th>
					<th scope="col">Name</th>
					<th scope="col">Email</th>
					<th scope="col">Phone</th>
					<th scope="col" class="text-end">Actions</th>
				</tr>
			</thead>
			<tbody>
				@foreach (var person in Model.Persons)
				{
					<tr>
						<th scope="row">@person.DNI</th>
						<td>@person.Name</td>
						<td>@person.Email</td>
						<td>@person.Phone</td>
						<td>
							<div class="table-actions">
								<a asp-action="GetPerson" asp-controller="GetPerson" asp-route-id="@person.Id" class="btn btn-sm btn-outline-primary">Edit</a>
								<form asp-action="DeletePerson" asp-controller="DeletePerson" asp-route-personId="@person.Id" method="post" data-delete-confirm="true">
									<button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
								</form>
							</div>
						</td>
					</tr>
				}
				@if (!Model.Persons.Any())
				{
					<tr>
						<td colspan="5" class="empty-table-message">No persons found.</td>
					</tr>
				}
			</tbody>
		</table>
	</div>
	<div class="person-pagination">
		<p>
			Showing @Model.Persons.Count() of @Model.TotalItems
		</p>
		<nav aria-label="Persons pagination">
			<ul class="pagination mb-0">
				<li class='page-item @(Model.HasPreviousPage ? string.Empty : "disabled")'>
					<a class="page-link"
					   asp-action="Index"
					   asp-controller="GetPersons"
					   asp-route-searchField="@Model.SearchField"
					   asp-route-searchTerm="@Model.SearchTerm"
					   asp-route-pageSize="@Model.PageSize"
					   asp-route-pageNumber="@(Model.PageNumber - 1)">Previous</a>
				</li>
				@if (Model.TotalPages > 0)
				{
					<li class='page-item @(Model.PageNumber == 1 ? "active" : string.Empty)'>
						<a class="page-link"
						   asp-action="Index"
						   asp-controller="GetPersons"
						   asp-route-searchField="@Model.SearchField"
						   asp-route-searchTerm="@Model.SearchTerm"
						   asp-route-pageSize="@Model.PageSize"
						   asp-route-pageNumber="1">1</a>
					</li>

					@if (showFirstPageGap)
					{
						<li class="page-item disabled">
							<span class="page-link pagination-gap">...</span>
						</li>
					}

					@for (int pageIndex = firstVisiblePage; pageIndex <= lastVisiblePage; pageIndex++)
					{
						<li class='page-item @(pageIndex == Model.PageNumber ? "active" : string.Empty)'>
							<a class="page-link"
							   asp-action="Index"
							   asp-controller="GetPersons"
							   asp-route-searchField="@Model.SearchField"
							   asp-route-searchTerm="@Model.SearchTerm"
							   asp-route-pageSize="@Model.PageSize"
							   asp-route-pageNumber="@pageIndex">@pageIndex</a>
						</li>
					}

					@if (showLastPageGap)
					{
						<li class="page-item disabled">
							<span class="page-link pagination-gap">...</span>
						</li>
					}

					@if (Model.TotalPages > 1)
					{
						<li class='page-item @(Model.PageNumber == Model.TotalPages ? "active" : string.Empty)'>
							<a class="page-link"
							   asp-action="Index"
							   asp-controller="GetPersons"
							   asp-route-searchField="@Model.SearchField"
							   asp-route-searchTerm="@Model.SearchTerm"
							   asp-route-pageSize="@Model.PageSize"
							   asp-route-pageNumber="@Model.TotalPages">@Model.TotalPages</a>
						</li>
					}
				}
				<li class='page-item @(Model.HasNextPage ? string.Empty : "disabled")'>
					<a class="page-link"
					   asp-action="Index"
					   asp-controller="GetPersons"
					   asp-route-searchField="@Model.SearchField"
					   asp-route-searchTerm="@Model.SearchTerm"
					   asp-route-pageSize="@Model.PageSize"
					   asp-route-pageNumber="@(Model.PageNumber + 1)">Next</a>
				</li>
			</ul>
		</nav>
	</div>
</section>
