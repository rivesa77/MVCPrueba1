@model PersonCollectionViewModel

@{
	ViewData["Title"] = "Persons";
}

<section class="page-header">
	<div>
		<p class="page-kicker">Directory</p>
		<h1>Persons</h1>
	</div>
	<a asp-action="Create" asp-controller="CreatePerson" class="btn btn-primary">Create Person</a>
</section>

<section class="surface">
	<div class="table-responsive">
		<table class="table align-middle person-table">
			<thead>
				<tr>
					<th scope="col">DNI</th>
					<th scope="col">Name</th>
					<th scope="col">Email</th>
					<th scope="col">Phone</th>
					<th scope="col" class="text-end">Actions</th>
				</tr>
			</thead>
			<tbody>
				@foreach (var person in Model.Persons)
				{
					<tr>
						<th scope="row">@person.DNI</th>
						<td>@person.Name</td>
						<td>@person.Email</td>
						<td>@person.Phone</td>
						<td>
							<div class="table-actions">
								<a asp-action="GetPerson" asp-controller="GetPerson" asp-route-id="@person.Id" class="btn btn-sm btn-outline-primary">Edit</a>
								<form asp-action="DeletePerson" asp-controller="DeletePerson" asp-route-personId="@person.Id" method="post" data-delete-confirm="true">
									<button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
								</form>
							</div>
						</td>
					</tr>
				}
			</tbody>
		</table>
	</div>
</section>
