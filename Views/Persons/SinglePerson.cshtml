@model PersonViewModel

@{
	ViewData["Title"] = "Edit Person";
}

<section class="page-header">
	<div>
		<p class="page-kicker">Persons</p>
		<h1>Edit person</h1>
	</div>
	<a asp-action="Index" asp-controller="GetPersons" class="btn btn-outline-secondary">Person List</a>
</section>

@if (!string.IsNullOrWhiteSpace(@Model.ErrorMessage))
{
	<div class="alert alert-primary person-message" role="alert">
		@Model.ErrorMessage
	</div>
}

@if (ViewBag.UpdateResult == true)
{
	<div class="alert alert-success person-message" role="alert">
		Update correctly
	</div>
}

<div id="noChangesMessage" class="alert alert-info person-message d-none" role="alert">
	No changes to update
</div>

<section class="surface form-surface">
	<form id="updatePersonForm" asp-action="UpdatePerson" asp-controller="UpdatePerson" asp-route-personId="@Model.Id" method="post"
		  data-person-form="true" data-detect-person-changes="true" data-no-changes-message="#noChangesMessage"
		  class="person-form">
		<div class="person-form-grid">
			<partial name="Persons/PersonFormFields" model="Model" />
		</div>

		<div class="form-actions">
			<button type="submit" class="btn btn-primary">Update Person</button>
		</div>
	</form>
</section>

<form asp-action="DeletePerson" asp-controller="DeletePerson" asp-route-personId="@Model.Id" method="post" class="danger-action">
	<button type="submit" class="btn btn-outline-danger">
		Delete Person
	</button>
</form>

@section Scripts {
	<partial name="Persons/PersonFormScripts" />
}
