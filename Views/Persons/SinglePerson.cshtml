@model PersonViewModel


@if (!string.IsNullOrWhiteSpace(@Model.ErrorMessage))
{
	<div class="alert alert-primary person-message" role="alert">
		@Model.ErrorMessage
	</div>
}

@if (ViewBag.UpdateResult == true)
{
	<div class="alert alert-success person-message" role="alert">
        Update correctly
	</div>
}

<div id="noChangesMessage" class="alert alert-info person-message d-none" role="alert">
	No changes to update
</div>

<form id="updatePersonForm" asp-action="UpdatePerson" asp-controller="UpdatePerson" asp-route-personId="@Model.Id" method="post"
	  data-person-form="true" data-detect-person-changes="true" data-no-changes-message="#noChangesMessage"
	  class="row row-cols-lg-auto g-3 align-items-center">

	<partial name="Persons/PersonFormFields" model="Model" />

	<div class="col-12">
		<button type="submit" class="btn btn-outline-primary">Update Person</button>
	</div>

</form>


<form asp-action="DeletePerson" asp-controller="DeletePerson" asp-route-personId="@Model.Id" method="post" class="d-inline">
	<button type="submit" class="btn btn-outline-danger">
		<i class="bi bi-archive"></i> Delete Person
	</button>
</form>

<a asp-action="Index" asp-controller="GetPersons" class="btn btn-primary">
	<i class="bi bi-archive"></i> Person List	
</a>

@section Scripts {
	<partial name="Persons/PersonFormScripts" />
}
