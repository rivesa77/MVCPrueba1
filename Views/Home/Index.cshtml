@model IndexViewModel

@{
	ViewData["Title"] = "Home Page";
}

@if (User.Identity?.IsAuthenticated ?? false)
{
	<section class="page-header">
		<div>
			<p class="page-kicker">Dashboard</p>
			<h1>Person management</h1>
		</div>
	</section>

	<section class="surface form-surface">
		<div class="home-actions">
			<a asp-action="Create" asp-controller="CreatePerson" class="btn btn-primary">Create Person</a>
			<a asp-action="Index" asp-controller="GetPersons" class="btn btn-outline-secondary">View Persons</a>
		</div>
	</section>
}
else
{
	<section class="welcome-panel">
		<h1>Welcome</h1>
	</section>
}
